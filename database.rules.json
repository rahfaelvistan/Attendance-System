{
  "rules": {
    ".read": false,
    ".write": false,

    // ==========================================
    // ADMIN & TEACHER CREDENTIAL NODES
    // These must be readable without auth since
    // teachers/admin have no Firebase Auth session.
    // Hashed passwords protect against brute-force.
    // ==========================================

    "admin_credentials": {
      ".read": true,
      ".write": "auth != null"
    },

    "settings": {
      "adminPassword": {
        ".read": true,
        ".write": "auth != null"
      }
    },

    "teachers": {
      ".read": true,
      ".indexOn": ["email"],
      ".write": "auth != null"
    },

    "teacher_credentials": {
      ".read": true,
      ".write": "auth != null"
    },

    // ==========================================
    // DATA NODES
    // Open to read for all clients (authenticated
    // or not), since teachers/admin are verified
    // at the application layer, not Firebase Auth.
    // Writes are open to allow teacher scanner to
    // record attendance without Firebase Auth token.
    // ==========================================

    "students": {
      ".read": true,
      ".write": true
    },

    "subjects": {
      ".read": true,
      ".write": true
    },

    "subject_enrollments": {
      ".read": true,
      ".write": true
    },

    "attendance": {
      ".read": true,
      ".write": true
    },

    "security_tokens": {
      ".read": true,
      ".write": true
    },

    "join_tokens": {
      ".read": true,
      ".write": true
    },

    "attendance_tokens": {
      ".read": true,
      ".write": true
    },

    // ==========================================
    // STUDENT CREDENTIALS NODES
    // Allows username/password login for students.
    // student_usernames: username → uid index lookup.
    // student_credentials: salted hash per student uid.
    // ==========================================

    "student_credentials": {
      ".read": true,
      ".write": true
    },

    "student_usernames": {
      ".read": true,
      ".write": true
    }
  }
}
